rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function isOwner(data) {
      return isSignedIn() && data.ownerId == request.auth.uid;
    }

    function isAdmin() {
      // In this app, we can check a 'users' collection for the role
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'COMPANY_ADMIN';
    }

    function isMember(companyId) {
       return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /companies/{companyId} {
      allow read: if isMember(companyId);
      allow write: if isSignedIn() && isMember(companyId) && isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && isMember(resource.data.companyId);
      allow create: if isSignedIn() && isMember(request.resource.data.companyId);
      allow update, delete: if isSignedIn() && isMember(resource.data.companyId);
    }

    match /sessions/{sessionId} {
      allow read: if isSignedIn() && isMember(resource.data.companyId);
      allow create: if isSignedIn() && isMember(request.resource.data.companyId);
      allow update: if isSignedIn() && isMember(resource.data.companyId);
    }
  }
}
